{
  "name": "aclang",
  "version": "0.1.5",
  "description": "AC Language Compiler v0.1.5 - A multi-target compiler for the AC programming language, note, this is more advanced than version 1",
  "bin": {
    "ac": "bin/ac",
    "install-backends": "scripts/install-backends.js"
  },
  "scripts": {
    "install": "node scripts/install.js",
    "build": "cd ac-compiler && make",
    "install-backends": "node scripts/install-backends.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "compiler",
    "ac-language",
    "multi-target",
    "cross-platform"
  ],
  "author": "Abu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AbuCodingAI/aclang.git"
  },
  "engines": {
    "node": ">=14.0.0",
    "python": ">=3.6.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "ac-compiler/",
    "docs/",
    "examples/",
    "library/",
    "scripts/",
    "website/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "vercel": "^53.1.0"
  }
}
