<mainloop>

     <LOGIC>

          <Local>
               Make factorial func(n)
                    IF n = 0
                         return 1
                    ELSEIF n = 1
                         return 1
                    OTHER
                         return fn n*(factorial(n-1))
          <Local>

          <StartHere>

               fruits = [$apple, banana, cherry$]
               FOR fruit in fruits
                    Term.display(fruit)

               result = factorial(5)
               Term.display(result)

               /kill

          <EndHere>

     <LOGIC>

<mainloop>
