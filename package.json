{
  "name": "aclang",
  "version": "0.2.0",
  "description": "AC Language Compiler — a multi-target language that compiles to Python, JavaScript, C++, Java, Rust, Go, V, ASM, and native binary (BNY). Features: Pratt parser, unified IR, ELSEIF chains, hash-based IR cache, DWARF debug info, and and/or keyword aliases.",
  "bin": {
    "ac": "bin/ac",
    "install-backends": "scripts/install-backends.js"
  },
  "scripts": {
    "install": "node scripts/install.js",
    "build": "cd ac-compiler && make",
    "install-backends": "node scripts/install-backends.js",
    "test": "bash tests/run.sh"
  },
  "keywords": [
    "compiler",
    "ac-language",
    "aclang",
    "multi-target",
    "cross-platform",
    "programming-language",
    "transpiler",
    "native-binary",
    "python-codegen",
    "javascript-codegen"
  ],
  "author": "Abu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AbuCodingAI/aclang.git"
  },
  "homepage": "https://github.com/AbuCodingAI/aclang#readme",
  "bugs": {
    "url": "https://github.com/AbuCodingAI/aclang/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "bin/",
    "scripts/",
    "examples/",
    "library/",
    "ac-compiler/ac",
    "ac-compiler/Makefile",
    "ac-compiler/setup.sh",
    "ac-compiler/setup.bat",
    "ac-compiler/install.py",
    "ac-compiler/ac_repl.py",
    "ac-compiler/src/",
    "ac-compiler/include/",
    "README.md",
    "LICENSE",
    "LANGUAGE_QUALITY_ROADMAP.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
