AC->PY *backend*

<mainloop>

     <LOGIC>

          * this runs once on startup *
          Term.display $Starting up...$

          <Local>
               Make factorial func(n)
                    IF n = 0
                         return 1
                    ELSEIF n = 1
                         return 1
                    OTHER
                         return fn n*(factorial(n-1))
          <Local>

          <StartHere>

               * this loops forever until /kill or Ctrl+C *
               fruits = [$apple, banana, cherry$]
               FOR fruit in fruits
                    Term.display(fruit)

               result = factorial(5)
               Term.display(result)

               /kill *stop after one loop for testing*

          <EndHere>

     <LOGIC>

<mainloop>
