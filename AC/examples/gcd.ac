AC->BNY

/* Euclidean GCD using repeated subtraction (no modulus needed) */

Make gcd func(a, b)
    WHILST a #= b
        IF a #< b
            a -= b
        OTHER
            b -= a
    return a

<mainloop>
    Term.display gcd(48, 18)
    Term.display gcd(100, 75)
    Term.display gcd(17, 13)
    /kill
<mainloop>
